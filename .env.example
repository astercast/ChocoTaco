# Copy to .env.local and fill in

# ─── Site URL (optional — absolute OG/Twitter preview image URLs in production) ─
# VITE_SITE_URL=https://your-domain.com

# ─── WalletConnect (required for connect) ────────────────────────────────────
VITE_WALLETCONNECT_PROJECT_ID=
VITE_CHAIN_ID=chia:mainnet

# ─── Backend (required for claims + network stats) ───────────────────────────
VITE_WORKER_URL=https://chocotaco-api.<your-subdomain>.workers.dev

# ─── Mint configuration ──────────────────────────────────────────────────────
# Mode A: open MintGarden drop page in new tab (default, easiest)
VITE_MINT_MODE=mintgarden
VITE_MINTGARDEN_DROP_SLUG=chocotaco-og        # e.g. mintgarden.io/drops/chocotaco-og

# Mode B: serve offer files from your Worker (advanced)
# VITE_MINT_MODE=offer

# ─── UI state toggles ────────────────────────────────────────────────────────
VITE_MINT_STATE=pre                            # 'pre' | 'live' | 'sold-out'
VITE_MINTED_COUNT=0                            # progress bar (or query /api/network-stats)
