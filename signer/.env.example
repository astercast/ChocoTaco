# Copy to .env, fill in

# CORS — your Cloudflare Worker URL
ALLOWED_ORIGIN=https://chocotaco-api.your-sub.workers.dev

# Chia node connection (defaults to local install)
CHIA_RPC_URL=https://localhost:9256
# CHIA_CERT_PATH=/home/youruser/.chia/mainnet/config/ssl/wallet/private_wallet.crt
# CHIA_KEY_PATH=/home/youruser/.chia/mainnet/config/ssl/wallet/private_wallet.key

# Wallet IDs (find with: chia wallet show)
CHIA_NFT_WALLET_ID=2

# Collection identifiers (from MintGarden after creating collection)
OG_COLLECTION_DID=did:chia:...
OG_COLLECTION_UUID=ab12cd34-...
COLLECTION_ICON_URL=https://your-cdn/icon.png

# Mint number starts after pre-minted Goldens (50 of them = 1..50)
MINT_START_NUMBER=51

# IPFS pinning — free token at https://nft.storage
NFT_STORAGE_KEY=

# Art assets directory
ART_DIR=./art

# Port
PORT=8080
